<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Package visibility (Play-friendly, replaces QUERY_ALL_PACKAGES): the picker only lists
         launchable apps, and the web filter needs to know which apps are browsers. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- The keyword filter must know the home-screen apps so it never blocks the launcher. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.HOME" />
        </intent>
    </queries>

    <!-- Lets the block screen appear over the blocked app. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Lets us measure how long an app is used (for daily limits). -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Lets us ask to be exempt from battery optimization so blocking keeps running. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- AI Coach + (github flavor) updater. The updater-install and Wi-Fi/Location-schedule
         permissions live in src/github/AndroidManifest.xml — the Play flavor must not carry
         them (self-updating and background location are Play-review problems). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Lets us alert the user if the blocking service gets silently disabled. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppBlocker">
        <!-- The launcher entry lives on exactly ONE of the icon aliases below (Profile ▸ App icon
             switches them via PackageManager). MainActivity itself stays enabled so explicit
             intents (notification deep-links, updater) keep working regardless of chosen icon. -->
        <!-- adjustResize: the keyboard must never PAN the window (HyperOS's fallback without
             this) — panning shoves the top bar off-screen and fights the Compose inset
             layouts (safeDrawingPadding) every text-entry screen relies on. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize" />

        <activity-alias
            android:name=".alias.IconHalo"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".alias.IconViolet"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_violet"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".alias.IconBlack"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_black"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".alias.IconLight"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_light"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".alias.IconSolid"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_solid"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".alias.IconLock"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_lock"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- The full-screen "Blocked" page. -->
        <activity
            android:name=".ui.BlockScreenActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Material.NoActionBar.Fullscreen" />

        <!-- Device admin: makes the app resist uninstall while enabled. -->
        <receiver
            android:name=".admin.AppBlockerAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Auto-blocks newly installed apps when that option is on. -->
        <receiver
            android:name=".service.PackageInstallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_FULLY_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- Re-arms the protection watchdog after a reboot, and arms the after-update
             blocking pause the moment the app is updated. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Optional: counts daily notifications for the Insights "Distractions" card.
             Only active while the user grants Notification access. -->
        <service
            android:name=".service.NotificationCountListener"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- The watcher: detects the foreground app and blocks it. -->
        <service
            android:name=".service.BlockerAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>

</manifest>
